{
  "name": "claude_worker_ver2",
  "display_name": "Claude Worker v2",
  "version": "0.3.0",
  "description": "Manager-layer file-protocol multi-agent orchestration for Claude Code. Dual-mode runners (-p/TUI), v2 role system with layered prompt injection, JSON state tracking.",
  "entry_skill": "SKILL.md",
  "requires": {
    "claude_code": "2.1.172"
  },
  "scripts": {
    "cli_manager": "scripts/ClaudeTui.ps1",
    "worker_launcher": "scripts/Send-ClaudeCommand.ps1",
    "completion_handler": "scripts/Complete-ClaudeTask.ps1 (deprecated)",
    "state_tracker": "scripts/Update-WorkerState.ps1",
    "runtime_cleanup": "scripts/Stop-ClaudeRuntime.ps1",
    "legacy": [
      "scripts/Start-ClaudeAgent.ps1",
      "scripts/Start-ClaudeBatch.ps1",
      "scripts/Stop-ClaudeAgent.ps1",
      "scripts/Wait-ClaudeCommand.ps1",
      "scripts/Wait-ClaudeBatch.ps1",
      "scripts/Get-ClaudeAgent.ps1",
      "scripts/Clear-ClaudeRuntime.ps1"
    ]
  },
  "state": {
    "canonical": "manager/agents.json"
  },
  "prompt_templates": {
    "default": "prompt_templates/default/",
    "roles": "prompt_templates/role/",
    "registry": "prompt_templates/roles.json"
  },
  "protocol": {
    "runners": ["-p", "tui"],
    "session_uuid_source": "filesystem scan (new) or done.json (subsequent)",
    "done": "store/<agent>/results/<command-id>.done.json",
    "result": "store/<agent>/results/<command-id>.result.md (convenience viewer, not authoritative)",
    "state": "run/<agent>/.<command-id>.state (JSON, authoritative exit signal)",
    "backend": "claude",
    "permissions": ".claude/worker-permissions.json",
    "system_prompt": "prompt_templates/default/system.md + role system_prompt/*.md (--system-prompt-file, layered)"
  },
  "stores": {
    "persistent": ["store/<agent>/results/", "prompt_templates/"],
    "transient": ["run/<agent>/"]
  }
}
